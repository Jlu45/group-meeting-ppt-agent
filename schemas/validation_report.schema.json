{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValidationReport",
  "description": "验证报告 - PPT质量检测的完整输出，包含分项评分、综合评分、等级和问题列表",
  "type": "object",
  "required": ["overall_score", "template_score", "layout_score", "content_score", "grade", "issues"],
  "additionalProperties": false,
  "properties": {
    "overall_score": {
      "type": "number",
      "description": "综合加权评分（0~1）",
      "minimum": 0,
      "maximum": 1
    },
    "template_score": {
      "type": "number",
      "description": "模板合规性评分（0~1），检测字体不匹配、颜色不匹配等",
      "minimum": 0,
      "maximum": 1
    },
    "layout_score": {
      "type": "number",
      "description": "布局合理性评分（0~1），检测文本溢出、元素重叠、边距违规、字体过小等",
      "minimum": 0,
      "maximum": 1
    },
    "content_score": {
      "type": "number",
      "description": "内容完整性评分（0~1），检测占位符文本、内容不完整等",
      "minimum": 0,
      "maximum": 1
    },
    "grade": {
      "type": "string",
      "description": "综合质量等级：A(≥0.85), B(0.70~0.85), C(0.60~0.70), D(<0.60)",
      "enum": ["A", "B", "C", "D"]
    },
    "issues": {
      "type": "array",
      "description": "验证问题列表",
      "items": {
        "$ref": "#/definitions/ValidationIssue"
      }
    }
  },
  "definitions": {
    "ValidationIssue": {
      "type": "object",
      "description": "验证问题 - 描述PPT验证过程中发现的一个具体问题",
      "required": ["id", "severity", "issue_type", "message", "suggested_fix"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "问题唯一标识"
        },
        "severity": {
          "type": "string",
          "description": "严重程度：critical(扣25分), error(扣15分), warning(扣8分), info(扣3分)",
          "enum": ["critical", "error", "warning", "info"]
        },
        "slide_id": {
          "type": ["string", "null"],
          "description": "关联的幻灯片ID（如 slide_1）"
        },
        "element_id": {
          "description": "关联的元素ID（shape_id）",
          "oneOf": [
            {"type": "string"},
            {"type": "integer"},
            {"type": "null"}
          ]
        },
        "issue_type": {
          "type": "string",
          "description": "问题类型及其所属检测层级",
          "enum": [
            "structure",
            "blank_slide",
            "missing_title",
            "text_overflow",
            "element_overlap",
            "margin_violation",
            "font_too_small",
            "font_mismatch",
            "color_mismatch",
            "placeholder_text",
            "incomplete_content"
          ]
        },
        "message": {
          "type": "string",
          "description": "问题描述"
        },
        "suggested_fix": {
          "type": "string",
          "description": "建议修复方案"
        }
      }
    }
  }
}
